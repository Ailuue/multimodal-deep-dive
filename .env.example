# Copy this file to `.env` and fill in the key for the stack you choose.
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Pick your provider. Vision (image input) works on BOTH. Audio and image
# generation are OpenAI-only — see the capability table below.
#
#   openai  -> vision + Whisper (STT) + TTS + image generation
#              (needs OPENAI_API_KEY)
#   claude  -> vision only; no audio, no image generation
#              (needs ANTHROPIC_API_KEY)
#
# Default is "openai" because it exercises every section of the repo. If you set
# PROVIDER=claude, the audio and image-generation examples will say so clearly
# and skip the API call rather than crash.
# ---------------------------------------------------------------------------
PROVIDER=openai

# --- For PROVIDER=openai ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- For PROVIDER=claude ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# The first two examples (offline vision mock + image token math) need NO key.
